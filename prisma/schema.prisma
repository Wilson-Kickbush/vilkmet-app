generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(uuid())
  nombre      String
  whatsapp    String
  email       String?
  status      String   @default("NUEVO")
  adminNotes  String?
  fechaAlta   DateTime @default(now())

  quotes      Quote[]
}

model Quote {
  id              String      @id @default(uuid())
  leadId          String
  linea           String      @default("")
  tipologia       String      @default("")
  ancho           Float       @default(0)
  alto            Float       @default(0)
  color           String      @default("")
  acristalamiento String      @default("")
  precioFinal     Float
  status          String      @default("nuevo")
  notasCliente    String?
  descuento       Float       @default(0)
  fechaCreacion   DateTime    @default(now())

  lead            Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  items           QuoteItem[]
}

model QuoteItem {
  id              String  @id @default(uuid())
  quoteId         String
  tipo            String
  linea           String
  tipologia       String
  ancho           Float
  alto            Float
  color           String
  acristalamiento String
  cantidad        Int     @default(1)
  subtotal        Float

  quote           Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

// ---> ESTA ES LA TABLA MAGICA QUE FALTABA PARA VER TUS FOTOS <---
model PortfolioProject {
  id          Int      @id @default(autoincrement())
  created_at  DateTime @default(now())
  title       String
  location    String
  description String
  type        String?
  image_url   String

  @@map("portfolio_projects") 
}

model SystemParameter {
  id          String   @id @default(uuid())
  clave       String   @unique
  valor       Float
  descripcion String?
  fechaUpdate DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(uuid())
  tipo        String
  categoria   String
  descripcion String
  monto       Float
  fecha       DateTime @default(now())
  mes         Int
  anio        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inventory {
  id            String   @id @default(uuid())
  nombre        String
  tipo          String
  cantidad      Float
  unidad        String
  stockMinimo   Float
  proveedor     String?
  costoUnitario Float?
  ubicacion     String?
  notas         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tipo])
  @@index([stockMinimo])
}