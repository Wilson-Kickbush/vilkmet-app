// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id         String   @id @default(uuid())
  nombre     String
  whatsapp   String
  email      String?
  status     String   @default("NUEVO") // NUEVO | CONTACTADO | PRESUPUESTADO | VENDIDO | PERDIDO
  adminNotes String?  // Para seguimiento interno de Wilson
  fechaAlta  DateTime @default(now())

  quotes     Quote[]
}

model Quote {
  id              String      @id @default(uuid())
  leadId          String
  // Legacy single-item fields (kept for backward compatibility)
  linea           String      @default("")
  tipologia       String      @default("")
  ancho           Float       @default(0)
  alto            Float       @default(0)
  color           String      @default("")
  acristalamiento String      @default("")
  precioFinal     Float
  // New fields
  status          String      @default("nuevo") // "nuevo" | "contactado" | "presupuestado" | "cerrado"
  notasCliente    String?
  descuento       Float       @default(0)       // Porcentaje de descuento aplicado por el admin
  fechaCreacion   DateTime    @default(now())

  lead            Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  items           QuoteItem[]
}

// Cada ítem del carrito multi-producto
model QuoteItem {
  id              String  @id @default(uuid())
  quoteId         String
  tipo            String  // "ventana" | "puerta"
  linea           String
  tipologia       String
  ancho           Float
  alto            Float
  color           String
  acristalamiento String
  cantidad        Int     @default(1)
  subtotal        Float

  quote           Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model SystemParameter {
  id          String   @id @default(uuid())
  clave       String   @unique
  valor       Float
  descripcion String?
  fechaUpdate DateTime @updatedAt
}

// Módulo de Contabilidad: Ingresos y Egresos
model Transaction {
  id          String   @id @default(uuid())
  tipo        String   // "INGRESO" | "EGRESO"
  categoria   String   // "VENTA" | "SEÑA" | "MATERIALES" | "SERVICIOS" | "PERSONAL" | "ALQUILER" | "OTRO"
  descripcion String
  monto       Float
  fecha       DateTime @default(now())
  mes         Int      // 1-12, para filtrado rápido
  anio        Int      // Año
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Módulo de Stock: Inventario de materiales
model Inventory {
  id          String   @id @default(uuid())
  nombre      String
  tipo        String   // "PROFILE" | "GLASS" | "COMPONENT"
  cantidad    Float
  unidad      String   // "metros" | "unidades" | "litros" | "rollos" | "kg"
  stockMinimo Float
  proveedor   String?
  costoUnitario Float?
  ubicacion   String?
  notas       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Índices para búsquedas rápidas
  @@index([tipo])
  @@index([stockMinimo])
}

